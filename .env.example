# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=chainbreaker
NEO4J_DATABASE=neo4j

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=network-flows
KAFKA_CONSUMER_GROUP=chainbreaker-consumers

# Spark
SPARK_MASTER=local[*]

# API
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=true

# ML Models
MODEL_DIR=models

# Data
DATA_DIR=data

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Frontend
FRONTEND_URL=http://localhost:5173
